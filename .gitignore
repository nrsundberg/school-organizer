# Prisma generated client only — DO NOT ignore /app/db entirely or the
# hand-written files (browser.ts, tenant-extension.ts, db.ts barrel)
# fall out of git and every fresh checkout fails to build.
/app/db/generated
/.idea
/node_modules
/.react-router
.env
.dev.vars
/build
/prisma/migrations/*/migration.sql
.wrangler/
.remember/

# Playwright
playwright-report/
test-results/
/blob-report/
/playwright/.cache/
.worktrees/
docs/agent-reports/*.patch
flow-tmp.mjs
scan-tmp.mjs
.trash-untracked-*

generator client {
  provider = "prisma-client"
  output   = "../app/db/generated"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

// better-auth tables
model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  emailVerified              Boolean   @default(false)
  name                       String    @default("")
  phone                      String?
  image                      String?
  role                       String    @default("VIEWER")
  mustChangePassword         Boolean   @default(false)
  banned                     Boolean   @default(false)
  banReason                  String?
  banExpires                 Int?
  /// "board" | "controller" (keypad); null defaults to board
  controllerViewPreference   String?
  orgId                      String?
  org                        Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  sessions                   Session[]
  accounts                   Account[]
  passwordResetTokens        PasswordResetToken[]
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([orgId])
}

/// Password-reset tokens for the "forgot password" flow. We store only the
/// sha256 of the token (never the raw token) so leaking this table alone
/// cannot be used to take over accounts.
model PasswordResetToken {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(token) — hex-encoded. The raw token is only ever in the email.
  tokenHash         String
  expiresAt         DateTime
  usedAt            DateTime?
  requestedAt       DateTime  @default(now())
  requestIp         String?
  requestUserAgent  String?

  @@index([tokenHash])
  @@index([userId])
}

model Org {
  id                     String                   @id @default(cuid())
  name                   String
  slug                   String                   @unique
  customDomain           String?                  @unique
  brandColor             String?
  brandAccentColor       String?
  /// Tenant palette override for --color-primary. Null = use default palette.
  /// Hex string, validated /^#[0-9a-fA-F]{6}$/ before persist.
  primaryColor           String?
  /// Tenant palette override for --color-secondary. Null = use default palette.
  secondaryColor         String?
  logoUrl                String?
  logoObjectKey          String?
  status                 OrgStatus                @default(ACTIVE)
  stripeCustomerId       String?                  @unique
  stripeSubscriptionId   String?                  @unique
  billingPlan            BillingPlan              @default(FREE)
  subscriptionStatus     StripeSubscriptionStatus?
  /// When the org began the product trial (signup). Used with qualifying pickup days.
  trialStartedAt         DateTime?
  /// Count of calendar days (UTC) with more than 10 distinct students called — qualifying “pickup” days.
  trialQualifyingPickupDays Int                   @default(0)
  /// Effective trial end: max(calendar 30d from start, completion of 25th qualifying day). Updated by cron.
  trialEndsAt              DateTime?
  /// First time any usage metric exceeded 100% of plan cap; 30-day grace to reach 110% or upgrade.
  usageGraceStartedAt      DateTime?
  /// Set when the Stripe subscription first becomes past_due; cleared when payment succeeds or sub ends past_due.
  pastDueSinceAt           DateTime?
  /// Platform ops notes (e.g. manual comp reasons).
  billingNote              String?
  /// When set, billing enforcement may treat the org as comped until this instant (UTC).
  compedUntil              DateTime?
  /// Hard-on comp flag set by staff from the platform admin panel. When true,
  /// billing enforcement (isOrgStatusAllowedForApp, trial-expiry suspension)
  /// is bypassed entirely. Use `compedUntil` for time-bounded comps.
  isComped                 Boolean                  @default(false)
  /// Whether this org's users can reset their password via email. Orgs using
  /// SSO should disable this so users are forced through the SSO flow.
  passwordResetEnabled     Boolean                  @default(true)
  users                  User[]
  appSettings            AppSettings[]
  viewerAccessAttempts   ViewerAccessAttempt[]
  viewerAccessSessions   ViewerAccessSession[]
  viewerMagicLinks       ViewerMagicLink[]
  teachers               Teacher[]
  students               Student[]
  spaces                 Space[]
  callEvents             CallEvent[]
  fireDrillTemplates     FireDrillTemplate[]
  fireDrillRuns          FireDrillRun[]
  auditLogs              OrgAuditLog[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
}

model OrgAuditLog {
  id           String   @id @default(cuid())
  orgId        String
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorUserId  String?
  action       String
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([orgId])
  @@index([orgId, createdAt])
}

/// Org-configurable checklist template (e.g. fire drill, lockdown).
model FireDrillTemplate {
  id          String          @id @default(cuid())
  orgId       String
  org         Org             @relation(fields: [orgId], references: [id])
  name        String
  definition  Json
  runs        FireDrillRun[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([orgId])
}

/// Latest run state for a template (toggles, notes, action items).
model FireDrillRun {
  id         String            @id @default(cuid())
  orgId      String
  org        Org               @relation(fields: [orgId], references: [id])
  templateId String            @unique
  template   FireDrillTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  state      Json
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([orgId])
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  payload       Json?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
}

/// Idempotency log for lifecycle/trial emails: prevents double-sends from the
/// daily cron. (orgId, kind, bucket) is the unique key; bucket encodes the
/// "slot" (e.g. "daysLeft=7", "day=14") so we can send multiple emails of
/// the same kind for different milestones.
model SentEmail {
  id        String   @id @default(cuid())
  orgId     String
  kind      String
  bucket    String
  sentAt    DateTime @default(now())

  @@unique([orgId, kind, bucket])
  @@index([orgId])
}

/// Single probe result (one row per component per tick). Written by the
/// 2-minute status cron. Retain for ~90 days for the uptime grid; latency
/// is stored but never surfaced publicly.
model StatusCheck {
  id          String   @id @default(cuid())
  componentId String
  /// 'operational' | 'degraded' | 'outage' | 'unknown'
  status      String
  latencyMs   Int?
  detail      String?
  checkedAt   DateTime @default(now())

  @@index([componentId, checkedAt(sort: Desc)], map: "StatusCheck_component_checkedAt_idx")
  @@index([checkedAt], map: "StatusCheck_checkedAt_idx")
}

/// Derived incident state. Opened after 3 consecutive non-operational checks;
/// closed after 2 consecutive operational checks. See
/// app/domain/status/runner.server.ts for the state machine.
model StatusIncident {
  id          String    @id @default(cuid())
  componentId String
  /// 'degraded' | 'outage'
  severity    String
  title       String
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  lastFailAt  DateTime?
  /// 'auto' (from runner) or 'manual' (future: operator posted note).
  source      String    @default("auto")

  @@index([startedAt(sort: Desc)], map: "StatusIncident_startedAt_idx")
}

/// Singleton row: use id "default"
model AppSettings {
  id                     String  @id
  orgId                  String  @default("org_tome")
  org                    Org     @relation(fields: [orgId], references: [id])
  viewerDrawingEnabled   Boolean @default(false)
  viewerPinHash          String?

  @@index([orgId])
}

model ViewerAccessAttempt {
  clientKey           String   @id
  orgId               String   @default("org_tome")
  org                 Org      @relation(fields: [orgId], references: [id])
  ipHint              String?
  failedCount         Int      @default(0)
  stage               Int      @default(0)
  lockedUntil         DateTime?
  requiresAdminReset  Boolean  @default(false)
  lastFailedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orgId])
}

model ViewerAccessSession {
  id           String   @id @default(cuid())
  orgId        String   @default("org_tome")
  org          Org      @relation(fields: [orgId], references: [id])
  tokenHash    String   @unique
  source       String
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
}

model ViewerMagicLink {
  id               String   @id @default(cuid())
  orgId            String   @default("org_tome")
  org              Org      @relation(fields: [orgId], references: [id])
  tokenHash        String   @unique
  expiresAt        DateTime
  usedAt           DateTime?
  revokedAt        DateTime?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orgId])
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// App domain models
model Teacher {
  id       Int       @id @default(autoincrement())
  orgId    String    @default("org_tome")
  org      Org       @relation(fields: [orgId], references: [id])
  homeRoom String    @unique
  students Student[]

  @@index([orgId])
  @@index([orgId, homeRoom])
}

model Student {
  id          Int      @id @default(autoincrement())
  orgId       String   @default("org_tome")
  org         Org      @relation(fields: [orgId], references: [id])
  firstName   String
  lastName    String
  /// Siblings share one household; each distinct household (or unassigned student) counts toward family cap.
  householdId String?
  space       Space?   @relation(fields: [spaceNumber], references: [spaceNumber])
  spaceNumber Int?
  teacher     Teacher? @relation(fields: [homeRoom], references: [homeRoom])
  homeRoom    String?
  callEvents  CallEvent[]

  @@index([orgId])
  @@index([householdId])
  @@index([spaceNumber])
  @@index([homeRoom])
  @@index([orgId, spaceNumber])
  @@index([orgId, homeRoom])
}

model Space {
  id          Int       @id @default(autoincrement())
  orgId       String    @default("org_tome")
  org         Org       @relation(fields: [orgId], references: [id])
  spaceNumber Int       @unique
  students    Student[]
  status      Status    @default(EMPTY)
  timestamp   String?
  callEvents  CallEvent[]

  @@index([orgId])
  @@index([spaceNumber])
  @@index([orgId, spaceNumber])
}

model CallEvent {
  id               Int      @id @default(autoincrement())
  orgId            String   @default("org_tome")
  org              Org      @relation(fields: [orgId], references: [id])
  space            Space    @relation(fields: [spaceNumber], references: [spaceNumber])
  spaceNumber      Int
  student          Student? @relation(fields: [studentId], references: [id])
  studentId        Int?
  studentName      String
  homeRoomSnapshot String?
  createdAt        DateTime @default(now())

  @@index([orgId])
  @@index([createdAt])
  @@index([spaceNumber])
  @@index([studentId])
  @@index([orgId, createdAt])
  @@index([orgId, spaceNumber])
  @@index([orgId, studentId])
}

enum Status {
  ACTIVE
  EMPTY
}

enum BillingPlan {
  /// Comped / staff-granted accounts only. Never chosen at public signup.
  FREE
  /// @deprecated Use CAR_LINE — migrated in DB; kept for compatibility with old clients.
  STARTER
  /// Base paid: single school car-line experience ($100/mo). The public default.
  CAR_LINE
  /// Premium single-school tier ($500/mo): higher caps, dedicated onboarding,
  /// priority support, SSO. Positioned on the public pricing page between
  /// CAR_LINE and DISTRICT.
  CAMPUS
  /// Multi-school district plan with custom pricing. Starts as a trialing org;
  /// the sales team finalizes pricing during the trial.
  DISTRICT
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  /// Non-payment: set by cron after 14-day grace while subscription remains past_due.
  SUSPENDED
  INCOMPLETE
  CANCELED
}

enum StripeSubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

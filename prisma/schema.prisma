generator client {
  provider = "prisma-client"
  output   = "../app/db/generated"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

// better-auth tables
model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  emailVerified              Boolean   @default(false)
  name                       String    @default("")
  phone                      String?
  image                      String?
  role                       String    @default("VIEWER")
  mustChangePassword         Boolean   @default(false)
  banned                     Boolean   @default(false)
  banReason                  String?
  banExpires                 Int?
  /// "board" | "controller" (keypad); null defaults to board
  controllerViewPreference   String?
  /// Preferred UI language (BCP-47 short code, e.g. "en", "es"). Defaults to
  /// "en" so existing rows are valid without a backfill. Updated via the
  /// `LanguageSwitcher` (which posts to /api/user-prefs).
  locale                     String    @default("en")
  orgId                      String?
  org                        Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  /// Set for district admins. Mutually exclusive with orgId and isPlatformAdmin
  /// at the application layer (validated in better-auth hooks).
  districtId   String?
  district     District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  sessions                   Session[]
  accounts                   Account[]
  passwordResetTokens        PasswordResetToken[]
  userInviteTokens           UserInviteToken[]
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([orgId])
  @@index([districtId])
}

/// Password-reset tokens for the "forgot password" flow. We store only the
/// sha256 of the token (never the raw token) so leaking this table alone
/// cannot be used to take over accounts.
model PasswordResetToken {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(token) — hex-encoded. The raw token is only ever in the email.
  tokenHash         String
  expiresAt         DateTime
  usedAt            DateTime?
  requestedAt       DateTime  @default(now())
  requestIp         String?
  requestUserAgent  String?

  @@index([tokenHash])
  @@index([userId])
}

/// Invite tokens for "staff creates a user" flow. The invitee clicks the link
/// in the email, sets a password, and is signed in — no temp password is ever
/// shown. Same sha256-hashed-token discipline as PasswordResetToken; longer
/// TTL (default 7 days) and a separate model so the audit trail stays clean.
model UserInviteToken {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(token) — hex-encoded. The raw token only lives in the email.
  tokenHash       String
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  /// Userid of the staff member who issued the invite. Nullable for system
  /// flows (e.g. district signup auto-provisions a school admin).
  invitedByUserId String?
  createdAt       DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model Org {
  id                     String                   @id @default(cuid())
  name                   String
  slug                   String                   @unique
  customDomain           String?                  @unique
  brandColor             String?
  brandAccentColor       String?
  /// Tenant palette override for --color-primary. Null = use default palette.
  /// Hex string, validated /^#[0-9a-fA-F]{6}$/ before persist.
  primaryColor           String?
  /// Tenant palette override for --color-secondary. Null = use default palette.
  secondaryColor         String?
  logoUrl                String?
  logoObjectKey          String?
  status                 OrgStatus                @default(ACTIVE)
  stripeCustomerId       String?                  @unique
  stripeSubscriptionId   String?                  @unique
  billingPlan            BillingPlan              @default(FREE)
  subscriptionStatus     StripeSubscriptionStatus?
  /// When the org began the product trial (signup). Used with qualifying pickup days.
  trialStartedAt         DateTime?
  /// Count of calendar days (UTC) with more than 10 distinct students called — qualifying “pickup” days.
  trialQualifyingPickupDays Int                   @default(0)
  /// Effective trial end: max(calendar 30d from start, completion of 25th qualifying day). Updated by cron.
  trialEndsAt              DateTime?
  /// First time any usage metric exceeded 100% of plan cap; 30-day grace to reach 110% or upgrade.
  usageGraceStartedAt      DateTime?
  /// Set when the Stripe subscription first becomes past_due; cleared when payment succeeds or sub ends past_due.
  pastDueSinceAt           DateTime?
  /// Platform ops notes (e.g. manual comp reasons).
  billingNote              String?
  /// When set, billing enforcement may treat the org as comped until this instant (UTC).
  compedUntil              DateTime?
  /// Hard-on comp flag set by staff from the platform admin panel. When true,
  /// billing enforcement (isOrgStatusAllowedForApp, trial-expiry suspension)
  /// is bypassed entirely. Use `compedUntil` for time-bounded comps.
  isComped                 Boolean                  @default(false)
  /// Whether this org's users can reset their password via email. Orgs using
  /// SSO should disable this so users are forced through the SSO flow.
  passwordResetEnabled     Boolean                  @default(true)
  /// Default UI language for this org. Used as a fallback for unauthenticated
  /// visitors on the tenant board, and as the locale for org-wide print views
  /// (print.board, print.master). See docs/i18n-contract.md.
  defaultLocale            String                   @default("en")
  /// Optional FK to District. When set, the org's own Stripe and trial
  /// fields are unused — billing flows through the district. Plan caps
  /// still apply per-school (each school inherits CAMPUS-tier limits).
  districtId             String?
  district               District?                @relation(fields: [districtId], references: [id], onDelete: SetNull)
  users                  User[]
  appSettings            AppSettings[]
  viewerAccessAttempts   ViewerAccessAttempt[]
  viewerAccessSessions   ViewerAccessSession[]
  viewerMagicLinks       ViewerMagicLink[]
  teachers               Teacher[]
  students               Student[]
  spaces                 Space[]
  callEvents             CallEvent[]
  drillTemplates         DrillTemplate[]
  drillRuns              DrillRun[]
  households             Household[]
  dismissalExceptions    DismissalException[]
  afterSchoolPrograms    AfterSchoolProgram[]
  programCancellations   ProgramCancellation[]
  auditLogs              OrgAuditLog[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([districtId])
}

model OrgAuditLog {
  id           String   @id @default(cuid())
  orgId        String
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorUserId  String?
  action       String
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([orgId])
  @@index([orgId, createdAt])
}

model District {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  logoUrl                  String?
  logoObjectKey            String?
  status                   OrgStatus                 @default(TRIALING)
  /// Soft cap. Districts that exceed are flagged in the staff panel; school
  /// creation is allowed but the district sees a banner and an audit-log
  /// entry is written.
  schoolCap                Int                       @default(3)
  stripeCustomerId         String?                   @unique
  stripeSubscriptionId     String?                   @unique
  subscriptionStatus       StripeSubscriptionStatus?
  billingPlan              BillingPlan               @default(DISTRICT)
  trialStartedAt           DateTime?
  /// Sales-set. No automatic enforcement at the district level — staff sets
  /// this manually from the platform admin panel.
  trialEndsAt              DateTime?
  pastDueSinceAt           DateTime?
  compedUntil              DateTime?
  isComped                 Boolean                   @default(false)
  billingNote              String?
  passwordResetEnabled     Boolean                   @default(true)
  defaultLocale            String                    @default("en")
  orgs                     Org[]
  users                    User[]
  auditLogs                DistrictAuditLog[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model DistrictAuditLog {
  id           String   @id @default(cuid())
  districtId   String
  district     District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actorEmail   String?
  action       String
  targetType   String?
  targetId     String?
  details      String?  // JSON-encoded
  createdAt    DateTime @default(now())

  @@index([districtId, createdAt])
}

/// Org-configurable safety drill template (fire, lockdown, secure, shelter, etc.).
/// globalKey is set when cloned from the seeded global library (see app/domain/drills/library.ts).
model DrillTemplate {
  id           String     @id @default(cuid())
  orgId        String
  org          Org        @relation(fields: [orgId], references: [id])
  name         String
  /// One of: FIRE | LOCKDOWN | SECURE | HOLD | EVACUATE | SHELTER | SEVERE_WEATHER |
  /// EARTHQUAKE | REUNIFICATION | BUS | BOMB_THREAT | MEDICAL | OTHER. Stored as TEXT
  /// because SQLite/D1 enums are awkward; narrowed in TS via DrillType.
  drillType    String     @default("OTHER")
  /// Source citation, e.g. "SRP v4.2", "NFPA 101". Null for org-custom templates.
  authority    String?
  /// Markdown directive teachers see before/during the drill (e.g. "Locks, Lights, Out of Sight").
  instructions String?
  /// Stable slug matching a key in the global library. Null for purely-custom templates.
  globalKey    String?
  definition   Json
  /// Default audience for new live runs from this template:
  /// "STAFF_ONLY" | "EVERYONE". Pre-selected on the start-live confirm.
  defaultAudience String     @default("EVERYONE")
  runs         DrillRun[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([orgId])
  @@index([globalKey])
}

/// A single run of a drill. Status state machine: DRAFT → LIVE → (PAUSED ↔ LIVE) → ENDED.
/// Note: a partial unique index enforced at the DB layer (see migrations/0021) guarantees
/// at most one LIVE or PAUSED run per org. Prisma can't model this; app code catches
/// the unique violation as a 409 "another drill is already live".
model DrillRun {
  id          String        @id @default(cuid())
  orgId       String
  org         Org           @relation(fields: [orgId], references: [id])
  templateId  String
  template    DrillTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  state       Json
  /// DRAFT | LIVE | PAUSED | ENDED. Backfill default is ENDED so historical runs are archived.
  status      String        @default("ENDED")
  /// Audience this run was started with: "STAFF_ONLY" | "EVERYONE".
  /// Frozen at start time. See DrillTemplate.defaultAudience.
  audience    String        @default("EVERYONE")
  activatedAt DateTime?
  pausedAt    DateTime?
  endedAt     DateTime?
  /// Userid of the human who last touched this run (toggle, note, lifecycle
  /// transition). Admin's id when impersonating; the user themself otherwise.
  /// Drills are admin/teacher-only so this should be non-null in practice,
  /// but the column is nullable for migration safety.
  lastActorUserId           String?
  /// Non-null when the most recent action was performed via impersonation.
  lastActorOnBehalfOfUserId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      DrillRunEvent[]

  @@index([orgId])
  @@index([templateId])
}

/// Per-action audit log for a DrillRun. One row per discrete user action
/// (cell toggle, note edit, action item change, lifecycle transition). The
/// drill replay UI on /admin/drills/history/:runId folds these forward from
/// the run's initial state to reconstruct the board at any point in time.
model DrillRunEvent {
  id               String   @id @default(cuid())
  runId            String
  run              DrillRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// "started" | "paused" | "resumed" | "ended" |
  /// "cell_toggled" | "notes_changed" |
  /// "action_added" | "action_edited" | "action_toggled" | "action_removed"
  kind             String
  /// Delta payload, kind-specific. Stored as a delta (not snapshot) so long
  /// drills don't bloat the table. See DrillEventPayload in app/domain/drills/types.ts.
  payload          Json
  actorUserId      String?
  onBehalfOfUserId String?
  occurredAt       DateTime @default(now())

  @@index([runId, occurredAt])
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  payload       Json?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
}

/// Idempotency log for lifecycle/trial emails: prevents double-sends from the
/// daily cron. (orgId, kind, bucket) is the unique key; bucket encodes the
/// "slot" (e.g. "daysLeft=7", "day=14") so we can send multiple emails of
/// the same kind for different milestones.
model SentEmail {
  id        String   @id @default(cuid())
  orgId     String
  kind      String
  bucket    String
  sentAt    DateTime @default(now())

  @@unique([orgId, kind, bucket])
  @@index([orgId])
}

/// Single probe result (one row per component per tick). Written by the
/// 2-minute status cron. Retain for ~90 days for the uptime grid; latency
/// is stored but never surfaced publicly.
model StatusCheck {
  id          String   @id @default(cuid())
  componentId String
  /// 'operational' | 'degraded' | 'outage' | 'unknown'
  status      String
  latencyMs   Int?
  detail      String?
  checkedAt   DateTime @default(now())

  @@index([componentId, checkedAt(sort: Desc)], map: "StatusCheck_component_checkedAt_idx")
  @@index([checkedAt], map: "StatusCheck_checkedAt_idx")
}

/// Derived incident state. Opened after 3 consecutive non-operational checks;
/// closed after 2 consecutive operational checks. See
/// app/domain/status/runner.server.ts for the state machine.
model StatusIncident {
  id          String    @id @default(cuid())
  componentId String
  /// 'degraded' | 'outage'
  severity    String
  title       String
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  lastFailAt  DateTime?
  /// 'auto' (from runner) or 'manual' (future: operator posted note).
  source      String    @default("auto")

  @@index([startedAt(sort: Desc)], map: "StatusIncident_startedAt_idx")
}

/// One row per org. orgId is the primary key — there is exactly one
/// AppSettings row per tenant. The `@default("org_tome")` is a type-system
/// convenience so callers don't need to pass orgId explicitly; the tenant
/// extension always overwrites it with the real orgId at runtime.
model AppSettings {
  orgId                  String  @id @default("org_tome")
  org                    Org     @relation(fields: [orgId], references: [id])
  viewerDrawingEnabled   Boolean @default(false)
  viewerPinHash          String?
}

model ViewerAccessAttempt {
  orgId               String   @default("org_tome")
  org                 Org      @relation(fields: [orgId], references: [id])
  clientKey           String
  ipHint              String?
  failedCount         Int      @default(0)
  stage               Int      @default(0)
  lockedUntil         DateTime?
  requiresAdminReset  Boolean  @default(false)
  lastFailedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@id([orgId, clientKey])
  @@index([orgId])
}

model ViewerAccessSession {
  id           String   @id @default(cuid())
  orgId        String   @default("org_tome")
  org          Org      @relation(fields: [orgId], references: [id])
  tokenHash    String
  source       String
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, tokenHash])
  @@index([orgId])
}

model ViewerMagicLink {
  id               String   @id @default(cuid())
  orgId            String   @default("org_tome")
  org              Org      @relation(fields: [orgId], references: [id])
  tokenHash        String
  expiresAt        DateTime
  usedAt           DateTime?
  revokedAt        DateTime?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, tokenHash])
  @@index([orgId])
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?
  /// Set when a district admin impersonates a school. The per-request
  /// middleware honors this over `User.orgId` so the existing
  /// tenant-extension scopes the request to the impersonated school.
  /// Cleared when impersonation ends.
  impersonatedOrgId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// App domain models
model Teacher {
  id       Int       @id @default(autoincrement())
  orgId    String    @default("org_tome")
  org      Org       @relation(fields: [orgId], references: [id])
  homeRoom String
  /// Optional per-teacher locale override for the homeroom print view.
  /// Null means "use Org.defaultLocale". Most teachers will leave this unset.
  locale   String?
  students Student[]

  @@unique([orgId, homeRoom])
  @@index([orgId])
}

model Student {
  id          Int      @id @default(autoincrement())
  orgId       String   @default("org_tome")
  org         Org      @relation(fields: [orgId], references: [id])
  firstName   String
  lastName    String
  /// Siblings share one household; each distinct household (or unassigned student) counts toward family cap.
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)
  space       Space?   @relation(fields: [orgId, spaceNumber], references: [orgId, spaceNumber])
  spaceNumber Int?
  teacher     Teacher? @relation(fields: [orgId, homeRoom], references: [orgId, homeRoom])
  homeRoom    String?
  callEvents  CallEvent[]
  dismissalExceptions DismissalException[]

  @@index([orgId])
  @@index([householdId])
  @@index([orgId, householdId])
  @@index([spaceNumber])
  @@index([homeRoom])
  @@index([orgId, spaceNumber])
  @@index([orgId, homeRoom])
}

model Household {
  id                  String               @id @default(cuid())
  orgId               String
  org                 Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                String
  pickupNotes         String?
  primaryContactName  String?
  primaryContactPhone String?
  students            Student[]
  exceptions          DismissalException[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orgId])
  @@index([orgId, name])
}

model DismissalException {
  id                String     @id @default(cuid())
  orgId             String
  org               Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  studentId         Int?
  student           Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  householdId       String?
  household         Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  /// DATE or WEEKLY; kept as TEXT for D1 compatibility.
  scheduleKind      String     @default("DATE")
  exceptionDate     DateTime?
  dayOfWeek         Int?
  startsOn          DateTime?
  endsOn            DateTime?
  dismissalPlan     String
  pickupContactName String?
  notes             String?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([orgId])
  @@index([orgId, exceptionDate])
  @@index([orgId, dayOfWeek])
  @@index([studentId])
  @@index([householdId])
}

model AfterSchoolProgram {
  id            String                @id @default(cuid())
  orgId         String
  org           Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  isActive      Boolean               @default(true)
  cancellations ProgramCancellation[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([orgId])
  @@index([orgId, name])
}

model ProgramCancellation {
  id               String             @id @default(cuid())
  orgId            String
  org              Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  programId        String
  program          AfterSchoolProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  cancellationDate DateTime
  title            String
  message          String
  /// IN_APP for now; EMAIL and SMS are the intended extension seam.
  deliveryMode     String             @default("IN_APP")
  createdByUserId  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([orgId])
  @@index([orgId, cancellationDate])
  @@index([programId])
}

model Space {
  id          Int       @id @default(autoincrement())
  orgId       String    @default("org_tome")
  org         Org       @relation(fields: [orgId], references: [id])
  spaceNumber Int
  students    Student[]
  status      Status    @default(EMPTY)
  timestamp   String?
  callEvents  CallEvent[]

  @@unique([orgId, spaceNumber])
  @@index([orgId])
  @@index([spaceNumber])
}

model CallEvent {
  id               Int      @id @default(autoincrement())
  orgId            String   @default("org_tome")
  org              Org      @relation(fields: [orgId], references: [id])
  space            Space    @relation(fields: [orgId, spaceNumber], references: [orgId, spaceNumber])
  spaceNumber      Int
  student          Student? @relation(fields: [studentId], references: [id])
  studentId        Int?
  studentName      String
  homeRoomSnapshot String?
  /// Userid of the human who triggered the dismissal. When an admin
  /// impersonates a parent and clicks, this is the ADMIN's id (the real
  /// human), and `onBehalfOfUserId` is the impersonated user. Nullable
  /// only for legacy rows pre-2026-04-26 (before the action endpoint
  /// was auth-gated to ADMIN/CONTROLLER, see update.$space.tsx); new
  /// CallEvent rows are always attributed to a signed-in actor.
  actorUserId       String?
  /// When non-null, the action was performed via impersonation and this
  /// is the impersonated user's id. Always null outside impersonation.
  onBehalfOfUserId  String?
  createdAt        DateTime @default(now())

  @@index([orgId])
  @@index([createdAt])
  @@index([spaceNumber])
  @@index([studentId])
  @@index([orgId, createdAt])
  @@index([orgId, spaceNumber])
  @@index([orgId, studentId])
  @@index([orgId, onBehalfOfUserId])
}

enum Status {
  ACTIVE
  EMPTY
}

enum BillingPlan {
  /// Comped / staff-granted accounts only. Never chosen at public signup.
  FREE
  /// @deprecated Use CAR_LINE — migrated in DB; kept for compatibility with old clients.
  STARTER
  /// Base paid: single school car-line experience ($100/mo). The public default.
  CAR_LINE
  /// Premium single-school tier ($500/mo): higher caps, dedicated onboarding,
  /// priority support, SSO. Positioned on the public pricing page between
  /// CAR_LINE and DISTRICT.
  CAMPUS
  /// Multi-school district plan with custom pricing. Starts as a trialing org;
  /// the sales team finalizes pricing during the trial.
  DISTRICT
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  /// Non-payment: set by cron after 14-day grace while subscription remains past_due.
  SUSPENDED
  INCOMPLETE
  CANCELED
}

enum StripeSubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

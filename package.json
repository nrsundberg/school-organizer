{
  "name": "pickup-roster",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build",
    "dev": "react-router dev",
    "dev:worker": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "d1:migrate": "wrangler d1 migrations apply --remote school-organizer",
    "d1:migrate:staging": "wrangler d1 migrations apply --remote school-organizer-staging --env staging",
    "d1:create-migration": "wrangler d1 migrations create",
    "backfill:org-id": "npx tsx scripts/backfill-org-id.ts",
    "typecheck": "react-router typegen && tsc",
    "test": "tsx --test app/domain/billing/*.test.ts app/domain/utils/*.test.ts app/lib/*.test.ts app/domain/drills/*.test.ts app/domain/csv/*.test.ts app/domain/auth/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@conform-to/react": "^1.19.0",
    "@conform-to/zod": "^1.19.0",
    "@heroui/react": "^3.0.1",
    "@prisma/adapter-d1": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@sentry/cloudflare": "^9.0.0",
    "@sentry/react-router": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "better-auth": "^1.5.0",
    "canvas-confetti": "^1.9.4",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.38.0",
    "isbot": "^5.1.37",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "react-toastify": "^11.0.5",
    "remix-toast": "^4.0.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "tiny-invariant": "^1.3.3",
    "zod": "^4.0.0",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@libsql/client": "^0.14.0",
    "@playwright/test": "^1.59.1",
    "@prisma/adapter-libsql": "^7.0.0",
    "@react-router/dev": "^7.13.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.8",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-babel": "^1.6.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "svix": "^1.92.2",
    "@sentry/react-router": {
      "glob": "^11.1.0"
    },
    "vite-plugin-devtools-json": {
      "uuid": "^14.0.0"
    }
  }
}
